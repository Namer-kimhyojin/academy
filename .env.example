# 환경변수 예시 (실제 값으로 채워 Render 대시보드의 Environment에 입력하세요)
# 로컬에서 DB 모드로 테스트하려면 이 값들을 셸 환경변수로 export 한 뒤 `npm start` 하면 됩니다.

# 관리자(분석 대시보드) 비밀번호 — 반드시 변경
ADMIN_PASSWORD=change-me-please

# Postgres 연결 문자열 (Neon 콘솔에서 복사). 없으면 자동으로 파일 저장 모드로 동작합니다.
# 예: postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# 포트 (Render는 자동 주입하므로 보통 설정 불필요)
# PORT=3000
